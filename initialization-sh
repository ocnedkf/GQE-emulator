#!/data/data/com.termux/files/usr/bin/bash
rm -r $HOME/.gqe-data
mkdir -p $HOME/.gqe-data
WINEDLLOVERRIDES="mscoree=" WINEPREFIX=$HOME/.gqe-data WINEARCH=win64 box64 wine64 wineboot -u

echo -e "Configuring Wine...\n"
wget -P $HOME/.gqe-data/drive_c/windows https://github.com/radzikpwnz/tfm/releases/download/v1.0.1/TFM.exe
wget https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/startmenulink.tar.xz
wget https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/startmenu.tar.xz
tar -xJf startmenu.tar.xz -C /data/data/com.termux/files/usr/opt
ls -d "$HOME/.gqe-data/drive_c/users/u*" | xargs -I {} tar -xJf startmenulink.tar.xz -C "{}/AppData/Roaming/Microsoft/Windows/Start Menu"
rm -f startmenulink.tar.xz startmenu.tar.xz
