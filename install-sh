#!/data/data/com.termux/files/usr/bin/bash
clear

echo -e "Welcome to the GQE installation script\n"
echo -e "We will now begin the installation process\n"
sleep 1

echo -e "Please grant storage permissions\n"
echo -e "If already granted, this can be ignored\n"
termux-setup-storage & sleep 0
sleep 10
if [ ! -e $HOME/storage ]; then
echo -e "Failed to check the directory , Please ensure that you have granted storage permissions\n"
exit 1
fi

echo -e "Updating termux package...\n"
apt-get clean
apt-get update >/dev/null 2>&1
apt-get -y --with-new-pkgs -o Dpkg::Options::="--force-confdef" upgrade >/dev/null 2>&1

echo -e "Installing necessary...\n"
pkg install x11-repo glibc-repo -y &>/dev/null
pkg install virglrenderer pulseaudio termux-x11-nightly glibc-runner alsa-lib-glibc freetype-glibc libpulse-glibc libx11-glibc libxcb-glibc libxext-glibc libxft-glibc libdrm-glibc libffi-glibc libicu-glibc libpciaccess-glibc libxml2-glibc libxshmfence-glibc libxi-glibc libxrandr-glibc vulkan-icd-loader-glibc tar xz-utils wget libepoxy-glibc libxkbcommon-glibc libxcursor-glibc libxcomposite-glibc libxinerama-glibc libmount-glibc libthai-glibc libgraphite-glibc libpixman-glibc libjpeg-turbo-glibc -y &>/dev/null

echo -e "Downloading additional dependencies...\n"
cd $HOME
rm -f lib.tar.xz
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/lib.tar.xz

echo ""
echo -e "Unpacking dependency packages...\n"
tar -xJf lib.tar.xz -C /data/data/com.termux/files/usr/glibc/lib
rm -f lib.tar.xz

echo ""
echo -e "Downloading Box64...\n"
rm -f box64.tar.xz
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/box64.tar.xz

echo ""
echo -e "Unpacking Box64...\n"
tar -xJf box64.tar.xz -C /data/data/com.termux/files/usr/glibc
rm -f box64.tar.xz


echo ""

while true; do

echo "Choose Wine version... (Input number then press Enter)"
echo ""
echo -e "1) Wine-9.16-custom (Old Version)\n"
echo -e "2) Proton-Wine-11.0 (Testing)\n"

read gqe

if [ "$gqe" = "1" ]; then
echo -e "Downloading Wine...\n"
rm -f winewow64.tar.xz
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/winewow64.tar.xz

echo ""
echo -e "Unzipping Wine...\n"
rm -rf /data/data/com.termux/files/usr/glibc/{lib/wine,share/applications/wine.desktop,share/wine,share/man}
tar -xJf winewow64.tar.xz -C /data/data/com.termux/files/usr/glibc
rm -f winewow64.tar.xz

clear
echo -e "Initializing Wine...\n"
wget --quiet https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/v0.2-beta/initialization-v0.1-sh
chmod +x initialization-v0.1-sh
./initialization-v0.1-sh
rm -f initialization-v0.1-sh

echo ""
echo -e "Initializing visual environment...\n"
wget --quiet -P $HOME/.gqe-data/drive_c https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/wallpaper.bmp
wget --quiet https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/wallpapersetting.reg
env WINEPREFIX=$HOME/.gqe-data-v0.2 grun /data/data/com.termux/files/usr/glibc/bin/box64 /data/data/com.termux/files/usr/glibc/bin/box64-bash /data/data/com.termux/files/usr/glibc/bin/regedit wallpapersetting.reg >/dev/null 2>&1
rm -f wallpapersetting.reg

echo ""
echo -e "Downloading GQE startup script ...\n"
wget --quiet --show-progress -P /data/data/com.termux/files/usr/bin https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/main/start-gqe
chmod 755 /data/data/com.termux/files/usr/bin/start-gqe

break

elif [ "$gqe" = "2" ]; then
echo -e "Downloading Wine...\n"
rm -f proton-wine-11.0-wow64.tar.xz
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/proton-wine-11.0-wow64.tar.xz

echo ""
echo -e "Unzipping Wine...\n"
rm -rf /data/data/com.termux/files/usr/glibc/{lib/wine,share/applications/wine.desktop,share/wine,share/man}
tar -xJf proton-wine-11.0-wow64.tar.xz -C /data/data/com.termux/files/usr/glibc
rm -f proton-wine-11.0-wow64.tar.xz

clear
echo -e "Initializing Wine...\n"
wget --quiet https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/v0.2-beta/initialization-sh
chmod +x initialization-sh
./initialization-sh
rm -f initialization-sh

echo ""
echo -e "Initializing visual environment...\n"
wget --quiet -P $HOME/.gqe-data-v0.2/drive_c https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/wallpaper.bmp
wget --quiet https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/wallpapersetting.reg
env WINEPREFIX=$HOME/.gqe-data-v0.2 grun /data/data/com.termux/files/usr/glibc/bin/box64 /data/data/com.termux/files/usr/glibc/bin/wine /data/data/com.termux/files/usr/glibc/bin/regedit "$(realpath wallpapersetting.reg)" >/dev/null 2>&1
rm -f wallpapersetting.reg

echo ""
echo -e "Downloading GQE startup script...\n"
wget --quiet --show-progress -P /data/data/com.termux/files/usr/bin https://gh-proxy.org/https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/v0.2-beta/start-gqe
chmod 755 /data/data/com.termux/files/usr/bin/start-gqe
break

else

clear
echo "Wrong input, choose again..."

fi
done

echo ""
echo -e "Configuring area files...\n"
rm -rf $HOME/.locale
mkdir -p $HOME/.locale
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i en_US $HOME/.locale/en_US.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i ja_JP $HOME/.locale/ja_JP.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i zh_CN $HOME/.locale/zh_CN.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i zh_TW $HOME/.locale/zh_TW.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i C $HOME/.locale/C.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i de_DE $HOME/.locale/de_DE.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i ko_KR $HOME/.locale/ko_KR.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i ru_RU $HOME/.locale/ru_RU.UTF-8

echo -e "Downloading Fonts...\n"
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.2-beta/fonts.tar.xz

echo ""
echo -e "Installing Fonts...\n"
mkdir -p /data/data/com.termux/files/usr/glibc/share/fonts
tar -xJf fonts.tar.xz -C /data/data/com.termux/files/usr/glibc/share/fonts
rm -f fonts.tar.xz

echo ""
echo -e "Downloading termination script...\n"
wget --quiet --show-progress -P /data/data/com.termux/files/usr/bin https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/v0.2-beta/kill-gqe
chmod +x /data/data/com.termux/files/usr/bin/start-gqe

echo ""
echo -e 'Starting to launch GQE, Next time use "start-gqe" command to run it\n'
sleep 2

start-gqe

clear
rm -rf "$0"
