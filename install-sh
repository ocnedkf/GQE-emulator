#!/data/data/com.termux/files/usr/bin/bash
clear

echo -e "Welcome to the GQE installation script\n"
echo -e "We will now begin the installation process\n"
sleep 1

echo -e "Please grant storage permissions\n"
echo -e "If already granted, this can be ignored\n"
termux-setup-storage & sleep 0
sleep 10
if [ ! -e $HOME/storage ]; then
echo -e "Failed to check the directory , Please ensure that you have granted storage permissions\n"
exit 1
fi

echo -e "Updating termux package...\n"
apt-get clean
apt-get update >/dev/null 2>&1
apt-get -y --with-new-pkgs -o Dpkg::Options::="--force-confdef" upgrade >/dev/null 2>&1

echo -e "Installing necessary...\n"
pkg install x11-repo glibc-repo -y &>/dev/null
pkg install pulseaudio termux-x11-nightly glibc-runner freetype-glibc libpulse-glibc libx11-glibc libxcb-glibc libxext-glibc libxft-glibc libxi-glibc libxrandr-glibc vulkan-icd-loader-glibc tar xz-utils wget -y &>/dev/null
cd $HOME
wget --quiet https://github.com/termux-pacman/glibc-packages/releases/download/20221025/gpft-20221025-aarch64.tar.xz
tar -xJf gpft-20221025-aarch64.tar.xz
tar -xJf glibc-for-termux/zlib-glibc-1:1.2.12-0-any.pkg.tar.xz
cp -r data/data/com.termux/files/usr/glibc/* /data/data/com.termux/files/usr/glibc/
rm -rf data .BUILDINFO .MTREE .PKGINFO glibc-for-termux gpft-20221025-aarch64.tar.xz

echo -e "Downloading Box64...\n"
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/box64.tar.xz

echo ""
echo -e "Unzipping Box64...\n"
tar -xJf box64.tar.xz -C /data/data/com.termux/files/usr/glibc
rm -f box64.tar.xz

echo -e "Downloading Wine...\n"
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/winewow64.tar.xz

echo ""
echo -e "Unzipping Wine...\n"
tar -xJf winewow64.tar.xz -C /data/data/com.termux/files/usr/glibc
rm -f winewow64.tar.xz

echo -e "Initializing Wine...\n"
wget --quiet https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/main/initialization-sh
chmod 755 initialization-sh
./initialization-sh
rm -f initialization-sh

echo -e "Configuring area files...\n"
mkdir -p $HOME/.locale
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i en_US $HOME/.locale/en_US.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i ja_JP $HOME/.locale/ja_JP.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i zh_CN $HOME/.locale/zh_CN.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i zh_TW $HOME/.locale/zh_TW.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i C $HOME/.locale/C.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i de_DE $HOME/.locale/de_DE.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i ko_KR $HOME/.locale/ko_KR.UTF-8
grun /data/data/com.termux/files/usr/glibc/bin/localedef -f UTF-8 -c -i ru_RU $HOME/.locale/ru_RU.UTF-8

echo -e "Downloading Fonts...\n"
wget --quiet --show-progress https://github.com/ocnedkf/GQE-emulator/releases/download/v0.1-beta/fonts.tar.xz

echo ""
echo -e "Installing Fonts...\n"
mkdir -p /data/data/com.termux/files/usr/glibc/share/fonts
tar -xJf fonts.tar.xz -C /data/data/com.termux/files/usr/glibc/share/fonts
rm -f fonts.tar.xz

echo -e "Downloading GQE startup script...\n"
wget --quiet --show-progress -P /data/data/com.termux/files/usr/bin https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/main/start-gqe
chmod 755 /data/data/com.termux/files/usr/bin/start-gqe

echo ""
echo -e 'Starting to launch GQE, Next time use "start-gqe" commad to run it\n'
sleep 2
start-gqe
exit 0
