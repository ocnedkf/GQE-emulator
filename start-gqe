#!/data/data/com.termux/files/usr/bin/bash

if [ ! -d "$HOME/.gqe-data/drive_c" ]; then
echo -e "Wine prefix missing,try reinitializing...\n"
wget https://raw.githubusercontent.com/ocnedkf/GQE-emulator/refs/heads/main/initialization-sh
./initialization-sh
rm -f initialization-sh
fi

rm -rf $PREFIX/tmp/pulse-*
pulseaudio -k >/dev/null 2>&1
pulseaudio --start --load="module-native-protocol-tcp auth-ip-acl=127.0.0.1 auth-anonymous=1" --exit-idle-time=-1 >/dev/null 2>&1

pkill -f X
termux-x11 :13 & >/dev/null 2>&1

am start -n com.termux.x11/.MainActivity

env BOX64_ASYNC=1 WINEPREFIX=$HOME/.gqe-data LOCPATH=$HOME/.locale PULSE_SERVER=127.0.0.1 DXVK_HUD=1 MESA_NO_ERROR=1 DISPLAY=:13 grun /data/data/com.termux/files/usr/glibc/bin/box64 /data/data/com.termux/files/usr/glibc/bin/wine64 explorer /desktop=1024x768 TFM.exe >/dev/null 2>&1
